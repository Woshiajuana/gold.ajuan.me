{
    "name": "file-storage-service",
    "version": "1.0.0",
    "description": "",
    "private": true,
    "egg": {
        "declarations": true
    },
    "dependencies": {
        "apidoc": "^0.17.7",
        "colorthief": "^2.3.2",
        "egg": "^2.15.1",
        "egg-cors": "^2.2.0",
        "egg-scripts": "^2.11.0",
        "images": "^3.2.3",
        "moment": "^2.24.0",
        "ms": "^2.1.2",
        "validator": "^13.5.2"
    },
    "devDependencies": {
        "autod": "^3.0.1",
        "autod-egg": "^1.1.0",
        "egg-bin": "^4.11.0",
        "egg-ci": "^1.11.0"
    },
    "engines": {
        "node": ">=10.0.0"
    },
    "scripts": {
        "start": "egg-scripts start --daemon --title=file-storage-service --framework=../lib/egg-wow-framework",
        "stop": "egg-scripts stop --title=file-storage-service",
        "dev": "npm run apidoc && egg-bin dev --framework=../lib/egg-wow-framework",
        "debug": "egg-bin debug",
        "test": "npm run lint -- --fix && npm run test-local",
        "test-local": "egg-bin test",
        "cov": "egg-bin cov",
        "lint": "eslint .",
        "ci": "npm run lint && npm run cov",
        "apidoc": "apidoc -i app/controller -o app/public/apidoc/",
        "autod": "autod"
    },
    "ci": {
        "version": "10"
    },
    "repository": {
        "type": "git",
        "url": ""
    },
    "author": "ajuan",
    "license": "MIT"
}
